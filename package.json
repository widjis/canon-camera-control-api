{
  "name": "camera-control",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Canon camera edge API backed by gphoto2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:edge": "tsx watch src/index.ts",
    "dev:control": "tsx watch src/control-index.ts",
    "dev:all": "concurrently -n edge,control -c blue,green \"npm:dev:edge\" \"npm:dev:control\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:edge": "node dist/index.js",
    "start:control": "node dist/control-index.js",
    "test": "node --test --import tsx test/**/*.test.ts"
  },
  "dependencies": {
    "dotenv": "^17.2.1",
    "fastify": "^5.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "concurrently": "^9.1.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
